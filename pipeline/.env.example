# apulia.ai Newsletter Pipeline — variabili d'ambiente
# Copia in .env e compila con i valori reali

# ── Anthropic (obbligatorio) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (obbligatorio per --publish e --deliver) ─────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── ZeptoMail (obbligatorio per --deliver) ────────────────
# Il token va nel formato completo come fornito da ZeptoMail
# es: "Zoho-enczapikey ..."
ZEPTO_API_KEY=Zoho-enczapikey ...
ZEPTO_FROM_EMAIL=newsletter@apulia.ai
ZEPTO_FROM_NAME=apulia.ai
