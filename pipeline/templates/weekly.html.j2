<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ nl.title }} — {{ nl.reporting_period }}</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>

{% set title_words = nl.title.rsplit(' ', 1) %}
{% macro brand_title() %}{% if title_words|length == 2 %}{{ title_words[0] }} <span class="accent">{{ title_words[1] }}</span>{% else %}{{ nl.title }}{% endif %}{% endmacro %}
{% macro bullet(b, show_date=true) %}
<li class="bullet-item">
  <span class="bullet-marker">▪</span>
  <span class="bullet-text">{{ b.text }}
    {% if b.sources %}
    <span class="bullet-sources">
      {% for s in b.sources %}<a href="{{ s.url }}" title="{{ s.name }}">{% if loop.index > 1 %}, {% endif %}{{ s.name }}{% if show_date and s.date %} {{ s.date }}{% endif %}</a>{% endfor %}
    </span>
    {% endif %}
  </span>
</li>
{% endmacro %}

{# ═══════════════════════════════════════════════════════════
   PARTE 1 — flusso editoriale continuo:
   Sviluppi chiave · Radar Normativo · Focus Italia · EN Summary
   · Briefing per paese · Funding · Compute · Incidenti
   ═══════════════════════════════════════════════════════════ #}
<div class="page">
  <div class="page-rule"></div>
  <div class="page-content">

    {# MASTHEAD #}
    <header>
      <div class="masthead">
        <img class="masthead-logo" src="apulia_ai.webp" alt="apulia.ai — AI News. Strategy. Impact.">
        <div class="issue-meta">
          <strong>{{ nl.reporting_period }}</strong><br>
          Generato il {{ now }}<br>
          {{ nl.article_count }} articoli · {{ nl.source_count }} fonti
        </div>
      </div>
      <div class="masthead-title-row">
        <div class="masthead-title">{{ brand_title() }}</div>
        <div class="masthead-tagline">{{ nl.tagline }}</div>
      </div>
    </header>

    {# ── SVILUPPI CHIAVE #}
    {% if nl.key_developments %}
    <div class="section">
      <div class="section-title">
        Sviluppi Chiave
        <span class="section-title-en">Key Developments</span>
      </div>
      <ul class="bullet-list">
        {% for b in nl.key_developments %}{{ bullet(b) }}{% endfor %}
      </ul>
    </div>
    {% endif %}

    {# ── RADAR NORMATIVO #}
    {% if nl.radar_normativo %}
    <div class="section">
      <div class="section-title">
        Radar Normativo
        <span class="section-title-en">Regulatory Radar · EU AI Act & Policy</span>
      </div>
      <ul class="bullet-list">
        {% for b in nl.radar_normativo %}{{ bullet(b) }}{% endfor %}
      </ul>
    </div>
    {% endif %}

    {# ── FOCUS ITALIA #}
    {% if nl.focus_italia %}
    <div class="section">
      <div class="section-title">
        Focus Italia
        <span class="section-title-en">Italy Focus</span>
      </div>
      <ul class="bullet-list">
        {% for b in nl.focus_italia %}{{ bullet(b) }}{% endfor %}
      </ul>
    </div>
    {% endif %}

    {# ── ENGLISH EXECUTIVE SUMMARY #}
    {% if nl.english_summary %}
    <div class="section">
      <div class="en-summary-box">
        <span class="en-summary-header">English Executive Summary</span><span class="en-note">For international readers · Sintesi per lettori internazionali</span>
        <ul class="bullet-list">
          {% for b in nl.english_summary %}{{ bullet(b, show_date=false) }}{% endfor %}
        </ul>
      </div>
    </div>
    {% endif %}

    {# ── DIVIDER DI CAPITOLO: BRIEFING PER PAESE #}
    <div class="chapter-divider">
      <span class="chapter-title">Briefing per Paese</span>
      <span class="chapter-title-en">Country Briefings · Funding · Compute · Rischi</span>
    </div>

    {# ── BRIEFING PER PAESE #}
    {% if nl.country_briefings %}
    <div class="section">
      <div class="section-title">
        Paesi Europei
        <span class="section-title-en">EU Countries</span>
      </div>
      <div class="country-grid">
        {% for cb in nl.country_briefings %}
        <div class="country-block">
          <div class="country-name">{{ cb.country }}</div>
          <ul class="bullet-list">
            {% for b in cb.bullets %}{{ bullet(b, show_date=false) }}{% endfor %}
          </ul>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {# ── FUNDING & MERCATI #}
    {% if nl.funding_markets %}
    <div class="section">
      <div class="section-title">
        Funding & Mercati
        <span class="section-title-en">Funding & Markets</span>
      </div>
      <ul class="bullet-list">
        {% for b in nl.funding_markets %}{{ bullet(b) }}{% endfor %}
      </ul>
    </div>
    {% endif %}

    {# ── COMPUTE & INFRASTRUTTURE #}
    {% if nl.compute_infra %}
    <div class="section">
      <div class="section-title">
        Compute & Infrastrutture
        <span class="section-title-en">Compute & Infrastructure</span>
      </div>
      <ul class="bullet-list">
        {% for b in nl.compute_infra %}{{ bullet(b, show_date=false) }}{% endfor %}
      </ul>
    </div>
    {% endif %}

    {# ── INCIDENTI & RISCHI AI #}
    {% if nl.incidents %}
    <div class="section">
      <div class="section-title">
        Incidenti & Rischi AI
        <span class="section-title-en">AI Incidents & Risks</span>
      </div>
      <ul class="bullet-list">
        {% for b in nl.incidents %}{{ bullet(b, show_date=false) }}{% endfor %}
      </ul>
    </div>
    {% endif %}

  </div>{# /page-content #}

  <footer class="page-footer">
    <span class="footer-brand">apulia<span class="accent">.ai</span></span>
    <span>{{ nl.reporting_period }} · {{ nl.tagline }}</span>
    <span class="footer-page">parte 1 / 2</span>
  </footer>
</div>


{# ═══════════════════════════════════════════════════════════
   PARTE 2 — dashboard: Spotlight · Matrice Capacità
   ═══════════════════════════════════════════════════════════ #}
<div class="page">
  <div class="page-rule"></div>
  <div class="page-content">

    <header class="page-header">
      <div class="header-brand">
        <img class="header-logo" src="apulia_ai.webp" alt="apulia.ai">
        <div class="header-divider"></div>
        <div>
          <div class="brand-name">{{ brand_title() }}</div>
          <div class="brand-tagline">Spotlight · Matrice Paesi × Capacità AI</div>
        </div>
      </div>
      <div class="issue-meta">
        <strong>{{ nl.reporting_period }}</strong>
      </div>
    </header>

    {# ── SPOTLIGHT #}
    {% if nl.spotlight_bullets %}
    <div class="section">
      <div class="spotlight-box">
        <div class="spotlight-kicker">Spotlight della Settimana · Weekly Spotlight</div>
        <div class="spotlight-title-it">{{ nl.spotlight_title_it }}</div>
        {% if nl.spotlight_title_en %}
        <div class="spotlight-title-en">{{ nl.spotlight_title_en }}</div>
        {% endif %}
        <ul class="bullet-list">
          {% for b in nl.spotlight_bullets %}{{ bullet(b, show_date=false) }}{% endfor %}
        </ul>
      </div>
    </div>
    {% endif %}

    {# ── MATRICE PAESI × CAPACITÀ AI #}
    <div class="section">
      <div class="section-title">
        Matrice Paesi × Capacità AI
        <span class="section-title-en">Country × AI Capability Matrix</span>
      </div>
      <table class="matrix-table">
        <thead>
          <tr>
            <th class="row-header">Paese</th>
            {% for cap in capabilities %}
            <th>{{ cap }}</th>
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          {% for country in countries %}
          {% set row = nl.capability_matrix.get(country, {}) %}
          <tr>
            <td class="country-cell">{{ country }}</td>
            {% for cap in capabilities %}
            {% set cell = row.get(cap) %}
            {% set state = cell.state if cell else 'none' %}
            {% set note = cell.note if cell else '' %}
            <td class="state-{{ state }}" title="{{ note }}">
              <span class="state-pill pill-{{ state }}">
                {% if state == 'none' %}—
                {% elif state == 'normal' %}●
                {% elif state == 'active' %}▲
                {% elif state == 'surge' %}★
                {% endif %}
              </span>
              {% if note %}<br><span class="matrix-note">{{ note }}</span>{% endif %}
            </td>
            {% endfor %}
          </tr>
          {% endfor %}
        </tbody>
      </table>

      {# Legenda #}
      <div class="matrix-legend">
        <span><span class="state-pill pill-none">—</span> Nessuna attività</span>
        <span><span class="state-pill pill-normal">●</span> Normale</span>
        <span><span class="state-pill pill-active">▲</span> Attivo</span>
        <span><span class="state-pill pill-surge">★</span> Surge</span>
      </div>
    </div>

    {# ── STATUS COMPUTE PER PAESE #}
    {% if nl.compute_status %}
    <div class="section">
      <div class="section-title">
        Stato Cloud & Data Center
        <span class="section-title-en">Cloud & Data Center Status</span>
      </div>
      <div class="compute-strip">
        {% for country in countries %}
        {% set state = nl.compute_status.get(country, 'none') %}
        <div class="compute-chip">
          <span class="state-pill pill-{{ state }}">{{ state|upper }}</span>
          <span>{{ country }}</span>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}

  </div>{# /page-content #}

  <footer class="page-footer">
    <span class="footer-brand">apulia<span class="accent">.ai</span></span>
    <span>{{ nl.reporting_period }} · {{ nl.tagline }}</span>
    <span class="footer-page">parte 2 / 2</span>
  </footer>
</div>

</body>
</html>
